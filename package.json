{
  "name": "content-discovery-service",
  "version": "1.0.0",
  "description": "Multi-platform content discovery via Stagehand browser automation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "search": "tsx src/cli.ts search",
    "jobs": "tsx src/cli.ts jobs",
    "scheduler": "tsx src/scheduler/cron.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node node_modules/playwright-core/cli.js install chromium || true"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@browserbasehq/stagehand": "^3.6.0",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "playwright-core": "^1.52.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
