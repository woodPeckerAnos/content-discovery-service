{
  "name": "content-discovery-service",
  "version": "1.0.0",
  "description": "Multi-platform content discovery via Stagehand browser automation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "search": "tsx src/cli.ts search",
    "login": "tsx src/cli.ts login",
    "jobs": "tsx src/cli.ts jobs",
    "worker": "tsx src/worker.ts",
    "server": "tsx src/server-main.ts",
    "build": "tsc",
    "start": "node dist/server-main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "setup:browsers": "tsx scripts/ensure-playwright-browsers.ts",
    "smoke": "tsx scripts/smoke.ts",
    "postinstall": "node node_modules/playwright-core/cli.js install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@browserbasehq/stagehand": "^3.6.0",
    "@koa/bodyparser": "^5.1.2",
    "@koa/router": "^13.1.0",
    "dotenv": "^16.4.7",
    "job-queue": "file:../job-queue/node",
    "koa": "^2.15.4",
    "pg": "^8.16.0",
    "playwright-core": "^1.52.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.15.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
