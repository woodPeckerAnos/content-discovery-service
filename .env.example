# LLM (default: DeepSeek)
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek/deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Browser（PC 宿主机 Worker）
HEADLESS=false
BROWSER_PROFILE_DIR=profiles/douyin
DATABASE_URL=postgres://dev:changeme@localhost:5432/content_discovery
BROWSER_CHANNEL=chrome

# Search defaults
MIN_RESULT_RATIO=0.9
MAX_SCROLLS=15
SCROLL_DELAY_MS=2000

# Redis / job-queue（连接 Docker 内 Redis，端口映射到宿主机）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
QUEUE_NAME=jobs
WORKER_CONCURRENCY=1
WORKER_NAME=content-discovery
# QUEUE_JOB_NAMES=douyin_search_crystal,douyin_search_home_cooking
QUEUE_JOBS_CONFIG_PATH=config/queue-jobs.yaml

# 本地 CLI 批量（非队列模式）
JOBS_FILE=config/jobs.example.json

# Output
RESULTS_DIR=results

# HTTP Server（PC 宿主机）
SERVER_PORT=3200
# API_TOKEN=your_secret_token
