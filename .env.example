# LLM (default: DeepSeek)
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek/deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# Browser
HEADLESS=false
BROWSER_PROFILE_DIR=profiles/douyin
# 使用本机 Google Chrome（推荐，登录态更稳定）；留空则用 Playwright 自带 Chromium
BROWSER_CHANNEL=chrome

# Search defaults
MIN_RESULT_RATIO=0.9
MAX_SCROLLS=15
SCROLL_DELAY_MS=2000

# Scheduler
CRON_ENABLED=false
CRON_SCHEDULE=0 9,21 * * *
JOBS_FILE=config/jobs.example.json

# Output
RESULTS_DIR=results
